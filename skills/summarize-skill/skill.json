{
  "name": "summarize",
  "version": "1.0.0",
  "description": "Summarize text content into a concise summary",
  "type": "skill",
  "author": "mcpzero-test",
  "parameters": {
    "type": "object",
    "properties": {
      "text": {
        "type": "string",
        "description": "The text content to summarize"
      },
      "max_sentences": {
        "type": "number",
        "description": "Maximum number of sentences in the summary",
        "default": 3
      }
    },
    "required": ["text"]
  },
  "tags": ["text", "summarization", "nlp"]
}
